{
    "Version":"2012-10-17",
    "Statement": [
        {
            "Effect":"Allow",
            "Action": ["s3:ListBucket"],
            "Principal": {"AWS":"*"},
            "Resource": "arn:aws:s3:::cloudfront-leanbay12345"
